# submitter -> worker SSH target
REMOTE_HOST=worker.example.internal
REMOTE_USER=taskd
REMOTE_PORT=22

# remote base dir on worker
REMOTE_BASE_DIR=/home/taskd/bash-task-kit

# local cache dir for fetched results (optional)
LOCAL_CACHE_DIR=./cache

# default timeout if task JSON omits it
DEFAULT_TIMEOUT_SEC=60

# worker polling interval
POLL_SEC=2
